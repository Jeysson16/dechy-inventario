rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && (
        !firestore.exists(/databases/(default)/documents/employees/$(request.auth.uid)) ||
        firestore.get(/databases/(default)/documents/employees/$(request.auth.uid)).data.role == 'admin'
      );
    }

    match /shipping-documents/{shipmentId}/{fileName} {
      allow read, write: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
