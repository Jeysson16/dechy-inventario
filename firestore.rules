rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Employee profiles are the source of application roles.
    // /settings/sunat contains only public issuer data.
    // /privateSettings/sunat, /fiscalCounters and /sunatOutbox are server-only.
    // /purchases contains received supplier documents for RCE/SIRE review.
    function hasEmployeeProfile() {
      return isAuth() && exists(/databases/$(database)/documents/employees/$(request.auth.uid));
    }

    // Helper: get the caller's employee profile
    function getProfile() {
      return get(/databases/$(database)/documents/employees/$(request.auth.uid)).data;
    }

    // Helper: check role
    function hasRole(role) {
      return hasEmployeeProfile() && getProfile().role == role;
    }

    function hasAnyRole(roles) {
      return hasEmployeeProfile() && roles.hasAny([getProfile().role]);
    }

    function isAdmin() {
      return hasRole('admin');
    }

    // Employees collection — admins full access; users can read their own doc
    match /employees/{uid} {
      allow read: if isAuth() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }

    // Branches — all users can read; only admins can write
    match /branches/{branchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categories — all users can read; only admins can write
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Products — all users can read; employees and above can write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAuth();
    }

    // Shipments — only admins can manage simulated international logistics
    match /envios/{envioId} {
      allow read, write: if isAdmin();
    }

    // Transactions — authenticated users can read/write
    match /transactions/{txId} {
      allow read, write: if isAuth();
    }

    // Fiscal settings contain privileged business configuration.
    match /settings/{settingId} {
      allow read, write: if isAdmin();
    }

    // Secrets and fiscal transport evidence are only accessed through the
    // authenticated backend using Firebase Admin SDK (which bypasses rules).
    match /privateSettings/{document=**} {
      allow read, write: if false;
    }

    match /fiscalCounters/{document=**} {
      allow read, write: if false;
    }

    match /sunatOutbox/{document=**} {
      allow read, write: if false;
    }

    match /purchases/{purchaseId} {
      allow read, create, update: if hasAnyRole(['admin', 'manager']);
      allow delete: if false;
    }

    // Compatibility rule for existing modules. Sensitive fiscal collections
    // must remain excluded because Firestore allow rules are additive.
    match /{collectionName}/{document=**} {
      allow read, write: if isAuth()
        && !['settings', 'privateSettings', 'fiscalCounters', 'sunatOutbox', 'purchases'].hasAny([collectionName]);
    }
  }
}
